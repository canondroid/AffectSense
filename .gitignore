# ── Personal / biometric data (privacy) ──────────────────────────────────
# Session recordings contain real facial and keystroke feature vectors.
# Collect your own: python -m src.training.collect_session --label calm|stress
data/sessions/

# RAF-DB facial expression dataset
# Download from http://www.whdeng.cn/RAF/model1.html and unzip to data/raw/RAF-DB/
data/raw/

# Processed FER training splits (generated by prepare_rafdb.py)
data/processed/

# ── Trained model files (personal, generated) ────────────────────────────
# XGBoost model + scaler — generated by: python -m src.training.train_xgb
models/xgb_model/

# SHAP explainer — generated alongside the XGBoost model
models/shap/

# FER model weights — generated by: python -m src.training.train_fer
# (~80 MB EfficientNet-B0 checkpoint; download or train separately)
models/fer_model/

